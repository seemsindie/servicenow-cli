{
  "name": "servicenow-cli",
  "version": "0.3.0",
  "description": "Command-line interface for ServiceNow. Multi-instance, multi-module, feature-parity with servicenow-mcp-server.",
  "type": "module",
  "private": true,
  "bin": {
    "sn": "./bin/sn"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "start": "bun run src/cli.ts",
    "build": "bun build --compile --target=bun src/cli.ts --outfile dist/sn",
    "build:release": "./scripts/build-release.sh",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "citty": "^0.1.6",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
